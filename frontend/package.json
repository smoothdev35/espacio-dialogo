{
  "name": "frontend",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "astro": "5.1.1",
    "@astrojs/react": "4.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "tailwindcss": "4.3.0",
    "@tailwindcss/postcss": "4.3.0",
    "postcss": "8.4.38",
    "eslint": "9.5.0",
    "typescript-eslint": "8.0.0-alpha.30",
    "prettier": "3.3.1",
    "eslint-plugin-astro": "1.0.1",
    "prettier-plugin-astro": "0.14.0",
    "prettier-plugin-tailwindcss": "0.6.4",
    "eslint-plugin-react": "7.34.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3"
  }
}
