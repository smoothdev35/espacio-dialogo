---
interface Option {
  value: string
  label: string
  disabled?: boolean
}

interface OptGroup {
  label: string
  options: Option[]
}

interface Props {
  label: string
  id: string
  name: string
  options: Option[]
  groups?: OptGroup[]
  placeholder?: string
  value?: string
  disabled?: boolean
  errorMessage?: string
  helperText?: string
  required?: boolean
  class?: string
}

const {
  label,
  id,
  name,
  options,
  groups,
  placeholder,
  value,
  disabled = false,
  errorMessage,
  helperText,
  required = false,
  class: className = '',
  ...rest
} = Astro.props

const hasError = !!errorMessage
const describedBy =
  [helperText ? `${id}-helper` : '', errorMessage ? `${id}-error` : '']
    .filter(Boolean)
    .join(' ') || undefined

const hasLeftIcon = Astro.slots.has('left-icon')

const selectClasses = [
  'w-full rounded-[var(--radius-input)] border bg-[var(--color-input)] text-[var(--color-input-text)] py-2 text-[var(--text-select)] font-[var(--font-body)]',
  'focus:bg-[var(--color-input-focus)] focus:border-[var(--color-input-focus-border)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-border-focus)]',
  'disabled:bg-[var(--color-input-disabled)] disabled:cursor-not-allowed disabled:opacity-60',
  hasError
    ? 'border-[var(--color-error)]'
    : 'border-[var(--color-input-border)]',
  // Adjust padding based on icon presence
  hasLeftIcon ? 'pl-9' : 'pl-3',
  'pr-3',
  className,
].join(' ')
---

<div class="flex flex-col gap-1">
  <label for={id} class="text-sm font-medium text-[var(--color-surface-text)]">
    {label}
    {
      required && (
        <span class="ml-1 text-[var(--color-error)]" aria-hidden="true">
          *
        </span>
      )
    }
  </label>
  <div class="relative">
    {
      hasLeftIcon && (
        <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-input-placeholder)]">
          <slot name="left-icon" />
        </span>
      )
    }
    <select
      id={id}
      name={name}
      value={value}
      disabled={disabled}
      required={required}
      aria-required={required ? 'true' : undefined}
      aria-invalid={hasError ? 'true' : undefined}
      aria-describedby={describedBy}
      class:list={[selectClasses]}
      {...rest}
    >
      {
        placeholder && (
          <option value="" disabled selected>
            {placeholder}
          </option>
        )
      }
      {
        groups
          ? groups.map((group) => (
              <optgroup label={group.label}>
                {group.options.map((opt) => (
                  <option
                    value={opt.value}
                    disabled={opt.disabled}
                    selected={opt.value === value}
                  >
                    {opt.label}
                  </option>
                ))}
              </optgroup>
            ))
          : options.map((opt) => (
              <option
                value={opt.value}
                disabled={opt.disabled}
                selected={opt.value === value}
              >
                {opt.label}
              </option>
            ))
      }
    </select>
  </div>
  {
    helperText && !hasError && (
      <p
        id={`${id}-helper`}
        class="text-sm text-[var(--color-surface-text)] opacity-70"
      >
        {helperText}
      </p>
    )
  }
  {
    hasError && (
      <p
        id={`${id}-error`}
        class="text-sm text-[var(--color-error)]"
        role="alert"
      >
        {errorMessage}
      </p>
    )
  }
</div>
