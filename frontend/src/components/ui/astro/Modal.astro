---
interface Props {
  id: string
  title: string
  triggerLabel?: string
  class?: string
}

const { id, title, triggerLabel, class: className = '' } = Astro.props
---

{
  triggerLabel && (
    <button
      type="button"
      data-modal-trigger={id}
      class="inline-flex items-center justify-center"
    >
      {triggerLabel}
    </button>
  )
}

<dialog
  id={id}
  aria-labelledby={`${id}-title`}
  class:list={[
    'rounded-large border border-border bg-surface p-0 text-surface-text backdrop:bg-black/50',
    'w-full max-w-lg',
    className,
  ]}
>
  <div class="flex flex-col gap-4 p-6">
    <div class="flex items-center justify-between">
      <h2
        id={`${id}-title`}
        class="text-lg font-semibold"
      >
        {title}
      </h2>
      <button
        type="button"
        data-modal-close={id}
        aria-label="Close dialog"
        class="inline-flex h-8 w-8 items-center justify-center rounded-full text-surface-text opacity-60 transition-colors hover:bg-surface hover:opacity-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <path d="M2 2l8 8M10 2l-8 8"></path>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <slot />
    </div>
  </div>
</dialog>

<script>
  document.querySelectorAll('[data-modal-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const id = trigger.getAttribute('data-modal-trigger')
      const dialog = document.getElementById(id!) as HTMLDialogElement
      if (dialog) {
        dialog.showModal()
      }
    })
  })

  document.querySelectorAll('[data-modal-close]').forEach((closeBtn) => {
    closeBtn.addEventListener('click', () => {
      const id = closeBtn.getAttribute('data-modal-close')
      const dialog = document.getElementById(id!) as HTMLDialogElement
      if (dialog) {
        dialog.close()
      }
    })
  })
</script>
