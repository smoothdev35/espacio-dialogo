---
interface Props {
  label: string
  id: string
  helperText?: string
  errorMessage?: string
  required?: boolean
  class?: string
}

const {
  label,
  id,
  helperText,
  errorMessage,
  required = false,
  class: className = '',
} = Astro.props

const hasError = !!errorMessage
---

<div class:list={['flex flex-col gap-1', className]}>
  <label for={id} class="text-sm font-medium text-[var(--color-surface-text)]">
    {label}
    {
      required && (
        <span class="ml-1 text-[var(--color-error)]" aria-hidden="true">
          *
        </span>
      )
    }
  </label>
  <slot />
  {
    helperText && !hasError && (
      <p
        id={`${id}-helper`}
        class="text-sm text-[var(--color-surface-text)] opacity-70"
      >
        {helperText}
      </p>
    )
  }
  {
    hasError && (
      <p
        id={`${id}-error`}
        class="text-sm text-[var(--color-error)]"
        role="alert"
      >
        {errorMessage}
      </p>
    )
  }
</div>
