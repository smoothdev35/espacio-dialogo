---
interface Props {
  label: string
  variant?: 'primary' | 'secondary' | 'tertiary' | 'link' | 'inverse' | 'inverse-outline'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  disabled?: boolean
  type?: 'button' | 'submit' | 'reset'
  icon?: string
  iconPosition?: 'leading' | 'trailing' | 'only'
  class?: string
}

const {
  label,
  variant = 'primary',
  size = 'md',
  href,
  disabled = false,
  type = 'button',
  icon,
  iconPosition,
  class: className = '',
  ...rest
} = Astro.props

const isLink = !!href
const Tag = isLink ? 'a' : 'button'

const baseClasses =
  'inline-flex items-center justify-center rounded-(--radius-button) transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus focus-visible:ring-offset-2 disabled:cursor-not-allowed'

const variantClasses: Record<string, string> = {
  primary: 'bg-btn-primary text-btn-primary-text border border-btn-primary-border hover:bg-btn-primary-hover active:bg-btn-primary-active disabled:bg-btn-primary-disabled disabled:text-btn-primary-disabled-text',
  secondary: `bg-btn-secondary text-btn-secondary-text border border-btn-secondary-border hover:bg-btn-secondary-hover active:bg-btn-secondary-active disabled:bg-btn-secondary-disabled disabled:text-btn-secondary-disabled-text`,
  tertiary: `bg-btn-tertiary text-btn-tertiary-text hover:bg-btn-tertiary-hover active:bg-btn-tertiary-active disabled:bg-btn-tertiary-disabled disabled:text-btn-tertiary-disabled-text`,
  link: `bg-btn-link text-btn-link-text hover:text-btn-link-hover active:text-btn-link-active disabled:text-btn-link-disabled-text underline-offset-4 hover:underline`,
  /**
   * 'inverse' variants hardcode light-mode colors so they don't swap on .dark toggle.
   * Intended for buttons rendered on an always-dark surface (e.g., hero image overlay)
   * where theme-based inversion would produce wrong contrast.
   */
  inverse:
    'bg-(--color-contrast-text) text-[#020306] border border-[#d9d9d9] hover:bg-[#f5f5f5] active:bg-[#e8e8e8] disabled:bg-[#d9d9d9] disabled:text-[#b3b3b4]',
  'inverse-outline':
    'bg-transparent text-(--color-contrast-text) border border-white/20 hover:bg-white/10 active:bg-white/20 disabled:opacity-50',
}

const sizeClasses: Record<string, string> = {
  sm:
    iconPosition === 'only'
      ? 'p-btn-icon-sm'
      : 'px-btn-x-sm py-btn-y-sm text-small',
  md:
    iconPosition === 'only'
      ? 'p-btn-icon-md'
      : 'px-btn-x-md py-btn-y-md',
  lg:
    iconPosition === 'only'
      ? 'p-btn-icon-lg'
      : 'px-btn-x-lg py-btn-y-lg text-large',
}

const linkProps = isLink ? { href, role: undefined } : {}
const buttonProps = !isLink ? { type, disabled } : {}
---

<Tag
  class:list={[
    baseClasses,
    variantClasses[variant],
    sizeClasses[size],
    className,
  ]}
  aria-label={iconPosition === 'only' ? label : undefined}
  {...linkProps}
  {...buttonProps}
  {...rest}
>
  {iconPosition === 'only' && <span class="sr-only">{label}</span>}
  {iconPosition === 'leading' && icon && <Fragment set:html={icon} />}
  {iconPosition !== 'only' && <span>{label}</span>}
  {iconPosition === 'trailing' && icon && <Fragment set:html={icon} />}
</Tag>
