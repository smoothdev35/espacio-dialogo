---
interface Props {
  label: string
  href: string
  external?: boolean
  class?: string
}

const {
  label,
  href,
  external = false,
  class: className = '',
  ...rest
} = Astro.props

const linkClasses = [
  'text-[var(--color-link-text)] underline-offset-4 hover:underline transition-colors duration-150',
  'hover:text-[var(--color-link-hover)] active:text-[var(--color-link-active)]',
  className,
].join(' ')
---

<a
  href={href}
  class:list={[linkClasses]}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  aria-label={external ? `${label} (opens in new tab)` : undefined}
  {...rest}
>
  {label}
  {external && <span class="sr-only"> (opens in new tab)</span>}
</a>
