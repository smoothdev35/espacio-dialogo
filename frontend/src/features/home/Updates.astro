---
/**
 * Updates
 *
 * Props: featured (FeaturedUpdateResult | null) — featured update card data
 *        gridArticles (UpdateCardProps[]) — updates for the 2x2 grid
 *        categories ({ name: string; slug: string }[]) — filter categories
 *        class? (string) — spread onto root <section> for consumer overrides
 * Slots: none
 * Tokens: --spacing-section-pad, --spacing-component-gap, --font-headline, --font-body
 * Hardcoded literals: none — page bg shows through via body
 * Context variants: not needed
 * Composed from: Container, FeaturedUpdateCard, UpdateGrid, UpdateFilters
 */

import Container from '@/layouts/Container.astro'
import FeaturedUpdateCard from '@/features/update/FeaturedUpdateCard.astro'
import UpdateGrid from '@/features/update/UpdateGrid.astro'
import UpdateFilters from '@/features/update/UpdateFilters.astro'
import type { UpdateCardProps } from '@/features/update/update.types'

interface Props {
  featured: UpdateCardProps | null
  gridArticles: UpdateCardProps[]
  categories: { name: string; slug: string }[]
  class?: string
}

const { featured, gridArticles, categories, class: className } = Astro.props
---

{/* Section bg is transparent — page background shows through via body */}
<section
  class:list={[
    className,
  ]}
  style="padding-block: var(--spacing-section-pad-large)"
>
  <Container>
    <div class="flex flex-col gap-component-gap">
      <!-- Tagline + heading + description -->
      <div class="flex flex-col">
        <p class="text-tagline font-semibold uppercase tracking-widest text-surface-text opacity-60 mb-4">
          Updates
        </p>
        <h1 class="mb-6">
          What's happening now
        </h1>
        <p class="max-w-2xl opacity-80">
          The latest developments in Nicaragua's ongoing transition.
        </p>
      </div>

      <!-- Filters — filtering handled client-side via script -->
      <UpdateFilters categories={categories} />

      <!-- Featured update card — only filterable when there's data -->
      {
        featured ? (
          <div data-update-featured data-card-category={featured.category?.slug ?? ''}>
            <FeaturedUpdateCard {...featured} />
          </div>
        ) : (
          <p class="text-small opacity-60">No featured update available.</p>
        )
      }

      <!-- Update grid (2x2) -->
      <UpdateGrid articles={gridArticles} />

      <!-- Empty state — shown when filter yields no results -->
      <p data-update-empty hidden class="col-span-full text-center text-surface-text opacity-60 py-12">
        No updates in this category
      </p>

      <!-- View all link -->
      <div class="flex justify-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-regular font-medium underline-offset-4 hover:underline"
        >
          View all updates
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 3l5 5-5 5" />
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>

<script>
  (function () {
    var nav = document.querySelector('[data-update-filters]')
    var grid = document.querySelector('[data-update-grid]')
    if (!nav || !grid) return

    var getItems = function () {
      var items = Array.from(grid.querySelectorAll('[data-card-category]'))
      var featured = document.querySelector('[data-update-featured]')
      if (featured) items.push(featured)
      return items
    }

    nav.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-filter-category]')
      if (!btn) return

      var category = btn.getAttribute('data-filter-category') || ''

      // Update button active states
      var buttons = nav.querySelectorAll('[data-filter-category]')
      for (var i = 0; i < buttons.length; i++) {
        var b = buttons[i]
        var isActive = b.getAttribute('data-filter-category') === category
        b.classList.toggle('bg-card-bg', isActive)
        b.classList.toggle('bg-transparent', !isActive)
        b.classList.toggle('font-normal', !isActive)
        b.classList.toggle('hover:bg-card-bg', !isActive)
        if (isActive) {
          b.setAttribute('aria-current', 'true')
        } else {
          b.removeAttribute('aria-current')
        }
      }

      // Show/hide cards by category
      var items = getItems()
      var anyVisible = false
      for (var j = 0; j < items.length; j++) {
        var el = items[j]
        var itemCat = el.getAttribute('data-card-category') || ''
        var hide = category !== '' && itemCat !== category
        el.hidden = hide
        if (!hide) anyVisible = true
      }

      // Show empty state when nothing matches filter
      var empty = document.querySelector('[data-update-empty]')
      if (empty) empty.hidden = anyVisible || category === ''
    })
  })()
</script>
