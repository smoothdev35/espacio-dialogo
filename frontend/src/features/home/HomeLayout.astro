---
/**
 * HomeLayout
 *
 * Props: featured (FeaturedArticleResult | null) — featured article for blog section
 *        gridArticles (ArticleCardProps[]) — grid articles for blog section
 *        categories ({ name: string; slug: string }[]) — filter categories
 *        class? (string) — spread onto root <div> for consumer overrides
 * Slots: none
 * Tokens: none directly — delegates to child components
 * Hardcoded literals: none
 * Context variants: not needed
 * Composed from: BlogUpdates
 */

import BlogUpdates from './BlogUpdates.astro'
import type { ArticleCardProps } from '@/features/article/article.types'
import type { FeaturedArticleResult } from '@/features/article/article.api'

interface Props {
  featured: FeaturedArticleResult | null
  gridArticles: ArticleCardProps[]
  categories: { name: string; slug: string }[]
  class?: string
}

const { featured, gridArticles, categories, class: className } = Astro.props
---

<div class:list={[className]}>
  <!-- Placeholder: Navbar will go here -->

  <!-- Placeholder: Header hero will go here -->
  <section class="text-center">
    <div class="max-w-(--container-large) px-page-gutters mx-auto">
      <h1>Democracy takes root in Nicaragua</h1>
    </div>
  </section>

  <!-- Blog / 24 / — Article listing section -->
  <BlogUpdates
    featured={featured}
    gridArticles={gridArticles}
    categories={categories}
  />

  <!-- Placeholder: Blog / 65 / slider will go here -->

  <!-- Placeholder: CTA section will go here -->

  <!-- Placeholder: Footer will go here -->
</div>
