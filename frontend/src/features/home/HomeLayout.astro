---
/**
 * HomeLayout
 *
 * Props: hero (HeroResult | null) — hero section content from Strapi
 *        featured (FeaturedUpdateResult | null) — featured update for blog section
 *        gridArticles (UpdateCardProps[]) — grid updates for blog section
 *        categories ({ name: string; slug: string }[]) — filter categories
 *        class? (string) — spread onto root <div> for consumer overrides
 * Slots: none
 * Tokens: none directly — delegates to child components
 * Hardcoded literals: none
 * Context variants: not needed
 * Composed from: Hero, BlogUpdates
 */

import Hero from './Hero.astro'
import BlogUpdates from './BlogUpdates.astro'
import type { UpdateCardProps } from '@/features/update/update.types'
import type { FeaturedUpdateResult } from '@/features/update/update.api'
import type { HeroResult } from './hero.api'

interface Props {
  hero: HeroResult | null
  featured: FeaturedUpdateResult | null
  gridArticles: UpdateCardProps[]
  categories: { name: string; slug: string }[]
  class?: string
}

const { hero, featured, gridArticles, categories, class: className } = Astro.props
---

<div class:list={[className]}>
  <!-- Hero renders fallback content when Strapi data is unavailable -->
  <Hero
    title={hero?.title}
    subtitle={hero?.subtitle}
    heroImage={hero?.heroImage ?? undefined}
  />

  <!-- Blog / 24 / — Article listing section -->
  <BlogUpdates
    featured={featured}
    gridArticles={gridArticles}
    categories={categories}
  />

  <!-- Placeholder: Blog / 65 / slider will go here -->

  <!-- Placeholder: CTA section will go here -->

  <!-- Placeholder: Footer will go here -->
</div>
