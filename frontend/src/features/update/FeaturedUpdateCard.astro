---
/**
 * FeaturedUpdateCard
 *
 * Props: title, slug, excerpt, readTime, featuredImage, category — from UpdateCardProps
 *        class? (string) — spread onto root <article> for consumer overrides
 * Slots: none
 * Tokens: --color-surface-text, --color-border, --radius-lg, --font-headline, --font-body
 * Hardcoded literals: border = color-mix(white 20%, transparent) — var(--color-border) resolves to same in dark mode
 *                     lg:min-h-[480px] — figma card height at desktop breakpoint
 * Context variants: not needed
 * Composed from: Tag (astro), Link (astro)
 */

import Tag from '@components/ui/astro/Tag.astro'
import Link from '@components/ui/astro/Link.astro'
import type { UpdateCardProps } from './update.types'

interface Props extends UpdateCardProps {
  class?: string
}

const {
  title,
  slug,
  excerpt,
  readTime,
  featuredImage,
  category,
  class: className,
} = Astro.props
---

<article
  class:list={[
    "flex flex-col lg:flex-row rounded-lg text-surface-text lg:min-h-[480px]",
    "bg-(--color-card-bg) border border-border overflow-hidden",
    className,
  ]}
>
  <!-- Featured image: 50% width, full card height -->
  {
    featuredImage && (
      <a
        href={`/blog/${slug}`}
        class="lg:w-1/2 overflow-hidden"
        aria-label={title}
      >
        <img
          src={featuredImage.url}
          alt={featuredImage.alternativeText ?? title}
          class="h-full w-full object-cover"
          loading="eager"
        />
      </a>
    )
  }

  <!-- Content panel: 50% width, 48px padding, button pinned to bottom -->
  <div class="flex flex-col justify-between p-12 lg:w-1/2">
    <!-- Top group: info row + heading + excerpt -->
    <div class="flex flex-col gap-4">
      <!-- Info row: category tag + readTime (no date) -->
      <div class="flex items-center gap-2">
        {
          category && (
            <Tag label={category.name} />
          )
        }
        <span class="text-small font-semibold opacity-80">
          {readTime}
        </span>
      </div>

      <!-- Heading: global h3 handles font/weight/leading; override size to h4 level (36/24px) -->
      <h3 class="text-h4">
        <a href={`/blog/${slug}`} class="hover:underline">
          {title}
        </a>
      </h3>

      <!-- Excerpt: card body is 16px (section-level body is 18px); opacity from design -->
      <p class="text-regular opacity-80">
        {excerpt}
      </p>
    </div>

    <!-- Bottom: Read more link -->
    <div>
      <Link
        href={`/blog/${slug}`}
        label="Read more"
      />
    </div>
  </div>
</article>
