---
/**
 * UpdateGrid
 *
 * Props: articles (UpdateCardProps[]) — list of updates to render in 2-column grid
 *        class? (string) — spread onto root <ul> for consumer overrides
 * Slots: none
 * Tokens: --spacing-component-gap
 * Hardcoded literals: none
 * Context variants: not needed
 * Composed from: UpdateCard
 */

import UpdateCard from './UpdateCard.astro'
import type { UpdateCardProps } from './update.types'

interface Props {
  articles: UpdateCardProps[]
  class?: string
}

const { articles, class: className } = Astro.props
---

<ul
  class:list={[
    "grid gap-component-gap md:grid-cols-2",
    className,
  ]}
>
  {
    articles.map((article) => (
      <li>
        <UpdateCard {...article} />
      </li>
    ))
  }
</ul>
