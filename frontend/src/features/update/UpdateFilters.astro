---
/**
 * UpdateFilters
 *
 * Props: categories ({ name: string; slug: string }[]) — list of filter categories
 *        class? (string) — spread onto root <nav> for consumer overrides
 * Slots: none
 * Tokens: --color-card-bg, --color-surface-text, --color-surface, --radius-tabs
 * Hardcoded literals: none
 * Context variants: not needed
 * Composed from: none (inline buttons)
 */

interface Props {
  categories: { name: string; slug: string }[]
  class?: string
}

const { categories, class: className } = Astro.props
---

<nav aria-label="Update category filters" class:list={[className]} data-update-filters>
  <ul class="flex flex-wrap gap-2">
    <!-- "All updates" — active by default -->
    <li>
      <button
        type="button"
        data-filter-category=""
        aria-current="true"
        class="rounded-tabs bg-card-bg text-surface-text px-4 py-2.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
      >
        All updates
      </button>
    </li>

    {
      categories.length > 0
        ? categories.map((cat) => (
            <li>
              <button
                type="button"
                data-filter-category={cat.slug}
                class="rounded-tabs bg-transparent text-surface-text font-normal px-4 py-2.5 hover:bg-card-bg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
              >
                {cat.name}
              </button>
            </li>
          ))
        : null
    }
  </ul>
</nav>
