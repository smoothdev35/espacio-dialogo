---
import BaseLayout from '@/layouts/BaseLayout.astro'
import HomeLayout from '@/features/home/HomeLayout.astro'
import { fetchArticles } from '@/features/article/article.api'

export interface Props {
  title?: string
}

const { title = 'Home — EDD' } = Astro.props

// Fetch articles with error fallback
const articleData = await fetchArticles().catch((err) => {
  console.error('Failed to fetch articles:', err)
  return {
    featured: null,
    grid: [],
    slider: [],
    categories: [],
  }
})
---

<BaseLayout title={title}>
  <HomeLayout
    featured={articleData.featured}
    gridArticles={articleData.grid}
    categories={articleData.categories}
  />
</BaseLayout>
