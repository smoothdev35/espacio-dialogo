{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "chrome-devtools-mcp@latest": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    }
  },
  "permission": {
    "tool": {
      "chrome-devtools-mcp_*": "deny"
    },
    "skill": {
      "astro-rules": "deny"
    }
  }
}